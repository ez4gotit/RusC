{
  "Точка входа — Князь": {
    "prefix": "князь",
    "body": [
      "Князь",
      "\t$0",
      "аминь"
    ],
    "description": "Создать точку входа программы"
  },
  "Объявить значение": {
    "prefix": "наречь",
    "body": [
      "наречь ${1:имя} суть ${2:значение}"
    ],
    "description": "Объявить значение с выводом типа"
  },
  "Условие": {
    "prefix": "аще",
    "body": [
      "аще ${1:условие}",
      "\t$0",
      "аминь"
    ],
    "description": "Условный блок"
  },
  "Счётный обход": {
    "prefix": "ступай",
    "body": [
      "ступай ${1:место} от ${2:0} до ${3:граница}",
      "\t$0",
      "аминь"
    ],
    "description": "Счётный цикл"
  },
  "Род": {
    "prefix": "род",
    "body": [
      "род ${1:Имя}",
      "\t$0",
      "аминь"
    ],
    "description": "Объявить объектный род"
  },
  "Наследующий род": {
    "prefix": "наследует",
    "body": [
      "род ${1:Потомок} наследует ${2:Предок}",
      "\t$0",
      "аминь"
    ],
    "description": "Объявить род с предком"
  },
  "Сокровенная черта": {
    "prefix": "черта",
    "body": [
      "сокровенная черта ${1|целое,дробное,строка,правдиво|} ${2:имя} суть ${3:значение}"
    ],
    "description": "Объявить скрытое поле"
  },
  "Зачин": {
    "prefix": "зачин",
    "body": [
      "всенародный зачин${1: при ${2:строка} ${3:имя}}",
      "\t$0",
      "аминь"
    ],
    "description": "Объявить конструктор рода"
  },
  "Умение": {
    "prefix": "умение",
    "body": [
      "всенародное умение ${1:пусто} ${2:имя}",
      "\t$0",
      "аминь"
    ],
    "description": "Объявить метод"
  },
  "Породить объект": {
    "prefix": "породить",
    "body": [
      "наречь ${1:порождение} суть породить ${2:Род}${3: ${4:аргумент}}"
    ],
    "description": "Создать объект"
  },
  "Вызвать умение": {
    "prefix": "воззови",
    "body": [
      "${1:порождение} воззови ${2:умение}${3: ${4:аргумент}}"
    ],
    "description": "Вызвать метод объекта"
  }
}
